{
  "input": {
    "images": [
      {
        "name": "reference_voice.wav",
        "image": "data:audio/wav;base64,PUT_YOUR_BASE64_ENCODED_WAV_HERE"
      }
    ],
    "workflow": {
      "1": {
        "inputs": {
          "audio": "reference_voice.wav",
          "upload": "image"
        },
        "class_type": "LoadAudio",
        "_meta": { "title": "Load Reference Audio" }
      },
      "2": {
        "inputs": {
          "model": "OmniVoice",
          "text": "This sentence will be spoken in the cloned voice from the reference audio.",
          "ref_text": "",
          "steps": 32,
          "guidance_scale": 2.0,
          "t_shift": 0.1,
          "speed": 1.0,
          "duration": 0.0,
          "device": "auto",
          "dtype": "auto",
          "attention": "auto",
          "seed": 42,
          "position_temperature": 5.0,
          "class_temperature": 0.0,
          "layer_penalty_factor": 5.0,
          "denoise": true,
          "preprocess_prompt": true,
          "postprocess_output": true,
          "keep_model_loaded": true,
          "instruct": "",
          "ref_audio": ["1", 0]
        },
        "class_type": "OmniVoiceVoiceCloneTTS",
        "_meta": { "title": "OmniVoice Voice Clone TTS" }
      },
      "3": {
        "inputs": {
          "filename_prefix": "ComfyUI_VoiceClone",
          "audio": ["2", 0]
        },
        "class_type": "SaveAudio",
        "_meta": { "title": "Save Audio" }
      }
    }
  }
}
