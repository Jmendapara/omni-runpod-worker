{
  "input": {
    "workflow": {
      "1": {
        "inputs": {
          "model": "OmniVoice",
          "text": "Hello! Welcome to OmniVoice. This is a demonstration of long-form text to speech with automatic chunking for longer content.",
          "ref_text": "",
          "steps": 32,
          "guidance_scale": 2.0,
          "t_shift": 0.1,
          "speed": 1.0,
          "duration": 0.0,
          "device": "auto",
          "dtype": "auto",
          "attention": "auto",
          "seed": 42,
          "words_per_chunk": 100,
          "position_temperature": 5.0,
          "class_temperature": 0.0,
          "layer_penalty_factor": 5.0,
          "denoise": true,
          "preprocess_prompt": true,
          "postprocess_output": true,
          "keep_model_loaded": true,
          "instruct": ""
        },
        "class_type": "OmniVoiceLongformTTS",
        "_meta": { "title": "OmniVoice Longform TTS" }
      },
      "2": {
        "inputs": {
          "filename_prefix": "ComfyUI_OmniVoice",
          "audio": ["1", 0]
        },
        "class_type": "SaveAudio",
        "_meta": { "title": "Save Audio" }
      }
    }
  }
}
